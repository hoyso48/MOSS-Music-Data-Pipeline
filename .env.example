# =============================================================================
# MOSS-Music Data Process Pipeline — Environment Variables
# Copy this file to .env and fill in the values that are relevant to you.
# =============================================================================

# --- API key for the inference services called by the pipeline ---
# (for ALM / ASR / LLM endpoints such as the Qwen3-Omni series, MusicFlamingo,
#  or other audio-language models exposed through an OpenAI-compatible gateway)
INF_API_KEY=

# --- HuggingFace mirror (optional, used by setup.sh when HF is slow) ---
# HF_ENDPOINT=https://hf-mirror.com

# --- OSS (MusicToolsPipeline, only needed for the OSS data loader) ---
OSS_META_DIR=
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# --- Lance S3 (MusicToolsPipeline, only needed for the Lance data loader) ---
LANCE_S3_ENDPOINT=
LANCE_S3_ACCESS_KEY_ID=
LANCE_S3_SECRET_ACCESS_KEY=
